{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A private note stored by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Public and private user profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "createdAt"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Collection of private notes"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profile data"
    }
  }
}
